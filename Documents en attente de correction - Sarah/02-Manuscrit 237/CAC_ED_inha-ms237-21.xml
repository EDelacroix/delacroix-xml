          <addrLine><persName
              key="Haro, Angélique Honorine Clotilde Osmont, épouse (v. 1802 - après 1863)">Madame
              Haro</persName>, marchande de couleurs</addrLine>
          <addrLine><placeName key="France, Paris, rue des Petits Augustins, 26">rue des Petits
              Augustins, 26</placeName></addrLine>
        </address>
        <stamp/>

        <pb n="p.2" facs="https://bibliotheque-numerique.inha.fr/i/?IIIF=/d0/1a/25/47/d01a2547-ee27-4d4d-a4a9-844a63cb176f/iiif/0644_doucet_ms237_000046.tif/full/full/0/default.jpg"/>
        <salute><persName key="Delacroix, Eugène (1798-1863)">Mr Delacroix</persName> salue bien
            <persName key="Haro, Angélique Honorine Clotilde Osmont, épouse (v. 1802 - après 1863)"
            >Madame Haro</persName></salute>
      </opener>

      <p>et la prie de vouloir bien m’envoyer à la Chambre des Députés que mardi seulement, les
        personnes pour coller ses figures. Il lui est impossible d’y aller lundi. Il y sera mardi 21
        à 8h ½.</p>

      <closer>
        <dateline>Ce <date when="1845-10-18">samedi soir 18 octobre <add place="inline">[1845]</add></date></dateline>
      </closer>

