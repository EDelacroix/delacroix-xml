  <text>
    <body>

      <pb n="p.1"
        facs="https://bibliotheque-numerique.inha.fr/i/?IIIF=/d0/1a/25/47/d01a2547-ee27-4d4d-a4a9-844a63cb176f/iiif/0644_doucet_ms237_000068.tif/full/full/0/default.jpg"/>
      <opener>
        <address>
          <addrLine><persName
              key="Haro, Angélique Honorine Clotilde Osmont, épouse (v. 1802 - après 1863)">Madame
              Haro</persName></addrLine>
          <addrLine>Marchande de couleurs</addrLine>
          <addrLine><placeName key="France, Paris, rue des Petits Augustins, 26">Rue des Petits
              Augustins, 26</placeName></addrLine>
        </address>
        <stamp><date when="1847-05-25">25 [184]7</date></stamp>
        <stamp>Levée de Midi</stamp>

        <pb n="p.2" facs="https://bibliotheque-numerique.inha.fr/i/?IIIF=/d0/1a/25/47/d01a2547-ee27-4d4d-a4a9-844a63cb176f/iiif/0644_doucet_ms237_000069.tif/full/full/0/default.jpg"/>
        <salute><persName key="Delacroix, Eugène (1798-1863)">M. Delacroix</persName> salue bien
            <persName key="Haro, Angélique Honorine Clotilde Osmont, épouse (v. 1802 - après 1863)"
            >Madame Haro</persName></salute>
      </opener>

      <p>et la prie de vouloir bien envoyer chercher au <placeName
          key="France, Paris, Musée du Louvre">musée</placeName><note place="bottom"> Il s'agit du
          musée du Louvre, où se tenait le Salon.</note> aussi tôt que possible ses tableaux et les
        lui rapporter. Elle laisserait au musée le reçu du <rs type="work" key="Corps de garde à Méquinez"><hi rend="u"
            >Corps de garde marocain</hi></rs><note place="bottom"><hi rend="it">Corps de garde à
            Méquinez</hi>.</note> mais en tirant elle-même une reconnaissance de ce que le reçu y a
        été laissé ; le tableau étant acquis par ledit musée<note place="bottom">Aujourd’hui
          conservé à Wuppertal, au Von der Heydt Museum.</note>.</p>
      
      <closer>
        <dateline>Ce <date when="1847-05-24">24 mai <add place="inline">[1847]</add></date></dateline>
      </closer>

    </body>
  </text>
