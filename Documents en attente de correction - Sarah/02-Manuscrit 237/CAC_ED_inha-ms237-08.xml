      <pb n="2" facs="https://bibliotheque-numerique.inha.fr/i/?IIIF=/d0/1a/25/47/d01a2547-ee27-4d4d-a4a9-844a63cb176f/iiif/0644_doucet_ms237_000019.tif/full/full/0/default.jpg"/>
      <p><persName key="Delacroix, Eugène (1798-1863)">Mr. Delacroix</persName> prie <persName
          key="Haro, Jacques François (1797-1844)">Monsieur Haro</persName> de passer chez lui <date
          when="1834-12-16">demain</date> dans la journée pour des bordures dont il a besoin
        bientôt.</p>
      
      <closer>
        <dateline>Ce <date when="1834-12-15">lundi 15 [décembre 1834]</date></dateline>
      </closer>

