  <text>
    <body>
      <pb n="p.1" facs="https://bibliotheque-numerique.inha.fr/i/?IIIF=/d0/1a/25/47/d01a2547-ee27-4d4d-a4a9-844a63cb176f/iiif/0644_doucet_ms237_000078.tif/full/full/0/default.jpg"/>
      <opener>
        <address>
          <addrLine><persName key="Haro, Étienne François (1827-1897)">Monsieur
            Haro</persName></addrLine>
          <addrLine>Marchand de couleurs</addrLine>
          <addrLine><placeName key="France, Paris, rue des Petits Augustins, 26">Rue des Petits Augustins, 26</placeName></addrLine>
        </address>
        <stamp><placeName key="France, Paris">Paris</placeName><date when="1851-10-20">20 oct 51</date></stamp>
        
        <pb n="p.2" facs="https://bibliotheque-numerique.inha.fr/i/?IIIF=/d0/1a/25/47/d01a2547-ee27-4d4d-a4a9-844a63cb176f/iiif/0644_doucet_ms237_000079.tif/full/full/0/default.jpg"/>

        <dateline>Ce <date when="1851-10-20">20 octobre <add place="inline">[1851]</add></date></dateline>

        <salute>Mon cher <persName key="Haro, Étienne François (1827-1897)"
          >Monsieur</persName>,</salute>
      </opener>
      
      <p>Je vous écris à la hâte, et en deux mots, que j’ai le logement d’<persName
          key="Étex, Antoine (1808-1888)">Etex</persName><note place="bottom"> Logement du sculpteur
          à l'Institut.</note>. Je ne veux pas ajourner jusqu’au moment où je pourrais vous voir
        pour vous annoncer cette nouvelle qui me fait beaucoup de plaisir et qui je crois vous en
        fera aussi.</p>
      
      <closer>
        <salute>Votre affectionné et dévoué</salute>
        <signed><persName key="Delacroix, Eugène (1798-1863)">Eug. Delacroix</persName></signed>
      </closer>
    </body>
  </text>
