    <text>
        <body>
            <opener>
                <pb n="2" xml:id="p2"/>
                <address>
                    <addrLine>Monsieur Pierret</addrLine>
                    <addrLine>rue neuve du Luxembourg</addrLine>
                    <addrLine>n<hi rend="sup">o</hi>. 1. —</addrLine>
                </address>

                <pb n="1" xml:id="p1"/>
                <dateline>
                    <date>mardi</date>
                </dateline>
                <salute>Cher ami,</salute>
            </opener>

            <p>M<hi rend="sup">lle</hi>. Bastien est au lit et incapable de m'assister ; je suis
                donc forcé de remettre notre partie de demain jusqu'à possibilité. J'en suis bien
                contrarié. J'ai été voir Dimanche soir ton train en bonne fortune</p>

            <closer>
                <salute>adieu je t'embrasse</salute>
                <signed>
                    <persName key="Delacroix, Eugène (1798-1863)">Eug</persName>
                </signed>
            </closer>
        </body>
    </text>
