    <text>
        <body>
            <pb n="1" xml:id="p1"/>
            <opener>
                <dateline><date when="1859-12-10">Ce 10 decembre <note place="inline"
                        >[1859]</note></date></dateline>
                <salute>Mon cher collègue,</salute>
            </opener>

            <p>voudriez vous me faire le plaisir de vous réunir à moi et à un petit nombre de nos
                collègues, pour dîner ensemble mercredi prochain 14, vous seriez bien aimable de me
                dire oui.</p>

            <closer>
                <salute>votre dévoué collègue</salute>
                <signed><persName key="Delacroix, Eugène (1798-1863)">E
                    Delacroix</persName></signed>
                <address>
                    <addrLine>rue de furstemberg 6</addrLine>
                    <addrLine>à 6 1/2.</addrLine>
                </address>
            </closer>
        </body>
