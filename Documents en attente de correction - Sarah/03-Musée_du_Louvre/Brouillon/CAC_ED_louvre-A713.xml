            <opener>
                <dateline><date when="1863-02-19">Ce 19 fevrier 1863</date></dateline>
            </opener>

            <p><persName key="Delacroix, Eugène (1798-1863)">M<hi rend="sup">r</hi>
                    Delacroix</persName> se rendra avec beaucoup d'empressement a l'invitation que
                Monsieur le Président du tribunal de commerce et Madame <persName
                    key="Denière, Guillaume (1815-1903)">Deniere</persName> lui ont fait l'honneur
                de lui adresser pour le 26 fevrier.</p>
