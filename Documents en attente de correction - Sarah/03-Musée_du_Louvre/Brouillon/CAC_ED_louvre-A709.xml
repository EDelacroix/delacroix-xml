    <text>
        <body>
            <pb n="1" xml:id="p1"/>
            <opener>
                <note place="margin-top-left" rend="pencil">III. 444</note>
                <salute>Mon cher ami,</salute>
            </opener>

            <p>Viens donc dîner demain avec moi. Je t'attendrai au coin du feu à six heures et
                demie.</p>

            <closer>
                <salute>Tout à toi.</salute>
                <signed>
                    <persName key="Delacroix, Eugène (1798-1863)">E Delacroix</persName>
                </signed>
            </closer>

            <note place="bottom-right" rend="pencil">39</note>
        </body>
