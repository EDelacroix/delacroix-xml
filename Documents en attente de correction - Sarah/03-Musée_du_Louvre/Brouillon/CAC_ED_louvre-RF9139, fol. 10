    <text>
        <body>
            <pb n="1" xml:id="fol10r" facs="CAC_ED_louvre-RF9139, fol. 10-1.jpg"/>
            <opener>
                <salute>Mon cher Henri</salute>
            </opener>
            
            <p>je t’aime de tou mon coeur, je pense à tout moment a toi, je</p>
            <pb n="2" xml:id="fol10v" facs="CAC_ED_louvre-RF9139, fol. 10-2.jpg"/>
            <p>voudrais te voir pour te caresser. reviens bien vite pour
                fair notre bonheur.</p>
            <closer>
                <signed>
                    <persName key="Delacroix, Eugène (1798-1863)">Eugene Delacroix</persName>
                </signed>
            </closer>
