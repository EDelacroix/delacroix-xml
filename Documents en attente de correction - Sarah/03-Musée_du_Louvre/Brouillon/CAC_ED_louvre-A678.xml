    <text>
        <body>
            <pb n="1" xml:id="p1"/>
            <opener>
                <note place="inline">T. 441</note>
                <note place="inline">30 octobre 1837</note>
                <salute>Mon cher Ricourt,</salute>
            </opener>

            <p>je vous avais écrit hier dimanche <lb/>en vous disant que je venais <lb/>ce matin
                lundi chercher le tableau <lb/>d’<title>Hamlet</title>. je vous priais dans le
                <lb/>cas où vous sortiriez d’indiquer <lb/>où on pourrait le prendre. j’arrive
                <lb/>ce matin et on n’a pu l’avoir. <lb/>ayez donc la bonté de l’envoyer : <lb/>j’en
                ai absolument besoin.</p>

            <closer>
                <salute>tout à vous</salute>
                <signed><persName key="Delacroix, Eugène (1798-1863)">Eug
                        Delacroix</persName></signed>
            </closer>

            <p>ce lundi matin.</p>
            <note place="inline">8</note>

            <pb n="2" xml:id="p2"/>
            <div type="address">

                <stamp> Tampon circulaire noir de la Petite Poste de Paris (bureau de quartier) :
                        <mentioned>R. DE LA MICHODIÈRE</mentioned> avec la lettre centrale
                        <mentioned>F</mentioned>. </stamp>
                <stamp type="postal" rend="ink(blue)" place="middle-right"> Tampon circulaire à date
                    de couleur bleue : <mentioned>PARIS / 30 / OCT. / 37</mentioned>. </stamp>
                <stamp> Tampon à date circulaire
                    noir (arrivée ou départ) : <mentioned>30 / OCT / 37</mentioned>. </stamp>
                <stamp> Reste d'un double tampon
                    circulaire noir linéaire, partiellement lisible. </stamp>

                <p>
                    <address>
                        <addrLine>Monsieur Ricourt</addrLine>
                        <addrLine><placeName>Place de la bourse</placeName></addrLine>
                        <addrLine>n° 9</addrLine>
                    </address>
                </p>
            </div>
        </body>
