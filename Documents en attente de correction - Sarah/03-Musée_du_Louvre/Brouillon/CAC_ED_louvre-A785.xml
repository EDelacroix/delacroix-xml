    <text>
        <body>
            <pb n="1" xml:id="p1" facs="CAC_ED_louvre-A785-1.jpg"/>
            <opener>
                <add place="top-right">27 bis</add>
                <salute>Mon cher Hippolyte,</salute>
            </opener>

            <p>voulez vous s’il vous plaît envoyer dans la journée à Mad. de Forget le prospectus de
                la campagne de votre frère. Elle verra demain une personne qui pourrait s’en
                accommoder. Ne manquez pas.</p>

            <closer>
                <salute>mille bonnes amitiés</salute>
                <signed>
                    <persName key="Delacroix, Eugène (1798-1863)">Eug Delacroix</persName>
                </signed>
                <dateline>ce dimanche</dateline>
            </closer>

            <pb n="2" xml:id="p2" facs="CAC_ED_louvre-A785-2.jpg"/>
            <closer>
                <address>
                    <addrLine>Monsieur Gaultron</addrLine>
                    <addrLine>rue de l’Université n° 8.</addrLine>
                </address>
            </closer>
        </body>
