    <body>
      <pb n="1"
        facs="https://bibliotheque-numerique.inha.fr/i/?IIIF=/89/c8/3c/4f/89c83c4f-4146-4989-b32f-3dd739e3c930/iiif/0644_doucet_MS236_000043.tif/full/full/0/default.jpg"/>
      <opener>
        <address>
          <addrLine><persName key="Sand, George (1804-1876)">Madame G.Sand </persName></addrLine>
          <addrLine><placeName key="France, Paris, rue Pigale, 16">rue Pigale n°
            16</placeName></addrLine>
        </address>
        <pb n="2"
          facs="https://bibliotheque-numerique.inha.fr/i/?IIIF=/89/c8/3c/4f/89c83c4f-4146-4989-b32f-3dd739e3c930/iiif/0644_doucet_MS236_000044.tif/full/full/0/default.jpg"/>
        <salute><persName key="Sand, George (1804-1876)">Chère amie</persName>,</salute>
      </opener>

      <p>soyez assez bonne pour me dire à quelle heure vous partirez de chez vous pour aller au
        cours de <persName key="Chopin, Frédéric (1810-1849)">Chopin</persName>. Nous irons
        ensemble.</p>

      <closer>
        <salute><persName key="Sand, George (1804-1876)">Adieu, bonne</persName>.</salute>
        <signed><persName key="Delacroix, Eugène (1798-1863)">Eug. Delacroix</persName></signed>
        <dateline><date when="1841-04-26">lundi</date> matin<note place="bottom">Il est possible de
            dater cette lettre au 26 avril 1841 grâce aux mentions de l'adresse de George Sand et
            l'ajout du "lundi matin". En effet, le concert de Chopin et d'Ernst eut lieu le jour
            même à la salle Pleyel (Alexandre, Françoise, <hi rend="it">Correspondance</hi>, 2005,
            p. 235 n. 1 de la page 109).</note></dateline>
      </closer>

    </body>
